# Contact form delivery endpoint (Formspree or any compatible JSON form handler).
# When set, ContactPage POSTs submissions here; when unset, the form falls back
# to optimistic local success (useful in dev / PR previews — nothing is sent).
#
# This value is inlined into the public client bundle at build time, so it is
# NOT a secret. In CI set it as a repository *variable* (vars.VITE_CONTACT_ENDPOINT),
# not a secret. Locally, copy this file to .env.local and fill it in.
VITE_CONTACT_ENDPOINT=https://formspree.io/f/your-form-id
